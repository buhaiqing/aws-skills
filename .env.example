# AWS Skill Development Environment Variables
# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control!

# ========================================
# Environment Variable Location
# ========================================
# When working within this repo: place .env at project root
# When mixing with other Skills (Aliyun/JD Cloud/etc): place .env in working directory (cwd)
# Custom path: use --env-file parameter

# ========================================
# Required: AWS API Credentials
# ========================================
# Get from: AWS Console → IAM → Security credentials → Access keys
# https://console.aws.amazon.com/iam/home#/security_credentials
# Standard AWS namespace prefix: AWS_*
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# ========================================
# Optional: Default Region
# ========================================
# Default: us-east-1
# Options: us-east-1, us-east-2, us-west-1, us-west-2, eu-west-1, ap-northeast-1, etc.
# Full list: https://docs.aws.amazon.com/general/latest/gr/rande.html
AWS_DEFAULT_REGION=us-east-1

# ========================================
# Optional: Session Token (for temporary credentials)
# ========================================
# Required when using IAM role assumed credentials or STS temporary tokens
# Leave empty if using long-term access keys
AWS_SESSION_TOKEN=

# ========================================
# Optional: CLI Configuration
# ========================================
# Output format for aws commands (json recommended for agents)
AWS_CLI_OUTPUT=json

# ========================================
# Optional: Development Settings
# ========================================
# Skill generation verbosity (true/false)
SKILL_GEN_VERBOSE=false

# ========================================
# Priority Order (Agent Runtime)
# ========================================
# 1. Shell environment variables (highest priority)
# 2. .env file values (this file)
# 3. Default values (lowest priority)
#
# Example: If you set `export AWS_DEFAULT_REGION=eu-west-1` in shell,
# it will override the value in this file.

# ========================================
# SECURITY WARNINGS
# ========================================
# 1. NEVER commit .env files to version control (.gitignore blocks this)
# 2. Use separate .env files for different environments (dev/staging/prod)
# 3. Rotate credentials regularly (every 90 days recommended)
# 4. Grant minimal permissions to API keys (least privilege principle)
# 5. Never share .env files via email, chat, or any unsecured channel
# 6. Prefer IAM roles over long-term access keys when possible

# ========================================
# Multi-Cloud Mixing Example (Optional)
# ========================================
# When mixing AWS Skills with other cloud provider Skills,
# use namespace prefixes to avoid credential conflicts.
#
# Example .env for multi-cloud environment:
#
# # AWS - AWS_* prefix (standard)
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_DEFAULT_REGION=us-east-1
#
# # JD Cloud - JDC_* prefix
# JDC_ACCESS_KEY=your_jdcloud_key
# JDC_SECRET_KEY=your_jdcloud_secret
# JDC_REGION=cn-north-1
#
# # Aliyun - ALIYUN_* prefix
# ALIYUN_ACCESS_KEY_ID=your_aliyun_key
# ALIYUN_ACCESS_KEY_SECRET=your_aliyun_secret
# ALIYUN_REGION=cn-hangzhou
#
# # Tencent Cloud - TENCENT_* prefix
# TENCENT_SECRET_ID=your_tencent_id
# TENCENT_SECRET_KEY=your_tencent_secret
# TENCENT_REGION=ap-guangzhou
#
# # Google Cloud Platform (GCP) - GCP_* prefix
# GCP_PROJECT_ID=your_gcp_project_id
# GCP_REGION=us-central1
# GCP_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json
# GCP_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
#
# # Microsoft Azure - AZURE_* prefix
# AZURE_SUBSCRIPTION_ID=your_subscription_id
# AZURE_TENANT_ID=your_tenant_id
# AZURE_CLIENT_ID=your_client_id
# AZURE_CLIENT_SECRET=your_client_secret
# AZURE_REGION=eastus
#
# # Huawei Cloud - HUAWEICLOUD_* prefix
# HUAWEICLOUD_ACCESS_KEY_ID=your_access_key_id
# HUAWEICLOUD_SECRET_ACCESS_KEY=your_secret_access_key
# HUAWEICLOUD_REGION=cn-north-4

# ========================================
# Credential Loading in Skills
# ========================================
# AWS Skills use {{env.AWS_ACCESS_KEY_ID}} and {{env.AWS_SECRET_ACCESS_KEY}}
# placeholders. Agent runtime loads these from:
# - Shell environment (export AWS_ACCESS_KEY_ID=xxx)
# - .env file (this file copied to .env)
#
# If credentials are missing, the skill will HALT with error:
# "Missing required credential: AWS_ACCESS_KEY_ID"